rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isTeacher() {
      return signedIn()
        && request.auth.token.email == "sssh1213@sssh.tyc.edu.tw";
    }

    function isSchoolAccount() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@sssh[.]tyc[.]edu[.]tw$')
        && request.auth.token.firebase.sign_in_provider == "google.com";
    }

    function isApprovedFriend() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.firebase.sign_in_provider == "google.com"
        && exists(/databases/$(database)/documents/allowedFriendEmails/$(request.auth.token.email))
        && get(/databases/$(database)/documents/allowedFriendEmails/$(request.auth.token.email)).data.active == true;
    }

    function isApprovedUser() {
      return isSchoolAccount() || isApprovedFriend();
    }

    function isOwner(userId) {
      return isApprovedUser() && request.auth.uid == userId;
    }

    match /allowedFriendEmails/{email} {
      allow get: if isTeacher() || (
        signedIn()
        && request.auth.token.email == email
        && request.auth.token.firebase.sign_in_provider == "google.com"
      );
      allow list, create, update, delete: if isTeacher();
    }

    match /groups/{groupId} {
      allow read, delete: if isTeacher();

      allow create, update: if isTeacher() || (
        isApprovedUser()
        && request.resource.data.groupCode == groupId
        && request.resource.data.keys().hasOnly([
          "groupCode",
          "lastActivityAt"
        ])
      );

      match /settings/{settingId} {
        allow read: if isApprovedUser();
        allow create, update, delete: if isTeacher();
      }

      match /bingoSubmissions/{userId} {
        allow read: if isTeacher() || isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.groupCode == groupId;

        allow update: if isTeacher() || (
          isOwner(userId)
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.groupCode == groupId
        );

        allow delete: if isTeacher();
      }

      match /leaderboard/{userId} {
        allow read: if isApprovedUser();

        allow create, update: if isTeacher() || (
          isOwner(userId)
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.groupCode == groupId
          && request.resource.data.keys().hasOnly([
              "ownerUid",
              "groupCode",
              "studentName",
              "className",
              "seatNumber",
              "earnedXp",
              "completionRate",
              "bingoCount",
              "updatedAt"
            ])
        );

        allow delete: if isTeacher();
      }
    }

    match /bingoSubmissions/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
